# External database
DATABASE_URL=postgresql://moleculens:moleculens@localhost:5432/moleculens

# Single-box database
POSTGRES_USER=moleculens
POSTGRES_PASSWORD=change-me
POSTGRES_DB=moleculens

# Paths
MOLECULE_CACHE_DIR=/var/molecule-cache
PSI_SCRATCH=/var/psi4_scratch

# Psi4 Configuration
PSI4_NUM_THREADS=1
PSI4_MEMORY_MB=512

# Worker
WORKER_POLL_SECONDS=1

# API
ALLOWED_ORIGINS=*
LOG_LEVEL=INFO

# TLS / domain
ACME_EMAIL=
MOLECULENS_DOMAIN=api.moleculens.com

# Protected cache metrics route
METRICS_AUTH_USER=metrics
# Quote bcrypt hashes in .env so Docker Compose preserves the $ characters.
METRICS_AUTH_PASSWORD_HASH=
